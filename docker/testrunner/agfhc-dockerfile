ARG BASE_IMAGE=registry.access.redhat.com/ubi9/ubi:9.6
FROM ${BASE_IMAGE}

LABEL maintainer="AMD Inc"
LABEL OS="registry.access.redhat.com/ubi9/ubi:9.6"

ARG AGFHC_VERSION=1.30.0
ARG ROCM_VERSION=7.2.1
ARG RADEON_REPO_URL=https://repo.radeon.com

# EPEL repo is required to install yaml-cpp, a dependency of rocm-validation-suite package
RUN dnf clean all && \
    rpm -ivh https://dl.fedoraproject.org/pub/epel/epel-release-latest-9.noarch.rpm && \
    echo "[ROCm-${ROCM_VERSION}]" > /etc/yum.repos.d/rocm.repo && \
    echo "name=ROCm${ROCM_VERSION}" >> /etc/yum.repos.d/rocm.repo && \
    echo "baseurl=${RADEON_REPO_URL}/rocm/rhel9/${ROCM_VERSION}/main" >> /etc/yum.repos.d/rocm.repo && \
    echo "enabled=1" >> /etc/yum.repos.d/rocm.repo && \
    echo "priority=50" >> /etc/yum.repos.d/rocm.repo && \
    echo "gpgcheck=1" >> /etc/yum.repos.d/rocm.repo && \
    echo "gpgkey=${RADEON_REPO_URL}/rocm/rocm.gpg.key" >> /etc/yum.repos.d/rocm.repo && \
    dnf update -y && \
    dnf install rocrand rocm-validation-suite -y && \
    rm -rf /var/cache/yum /var/cache/dnf && \
    dnf clean all

# Security patch for multiple CVEs
RUN dnf update -y libarchive libxml2 pam python3-requests glibc && \
    rm -rf /var/cache/yum /var/cache/dnf && \
    dnf clean all

# Required by RVS level based test recipes
# 1. Install dkms package
# 2. Modify the level 1 test recipes since not all packages are required in the container environment
RUN dnf install https://dl.fedoraproject.org/pub/epel/epel-release-latest-9.noarch.rpm -y && \
    dnf config-manager --add-repo=https://mirror.stream.centos.org/9-stream/BaseOS/x86_64/os/ && \
    dnf config-manager --add-repo=https://mirror.stream.centos.org/9-stream/AppStream/x86_64/os/ && \
    rpm --import https://www.centos.org/keys/RPM-GPG-KEY-CentOS-Official && \
    dnf install dkms -y && \
    rm -rf /var/cache/yum /var/cache/dnf && \
    dnf clean all && \
    find /opt/rocm/share/rocm-validation-suite/conf -name '*level_1*' -type f -exec sed -i '/^[[:space:]]*package:/d; /^[[:space:]]*debpackagelist:/d; s/^[[:space:]]*rpmpackagelist:.*/  rpmpackagelist: rocm-core rocminfo comgr rocblas rocrand hsa-rocr hip-runtime-amd/' {} \;

# Install AGFHC
WORKDIR /agfhc

RUN dnf install tar bzip2 python3-pyyaml wget rocm-smi-lib -y && \
    wget https://atlartifactory.amd.com:8443/artifactory/HW-AGFHCRelease-REL-LOCAL/${AGFHC_VERSION}/mi300/agfhc-mi300_${AGFHC_VERSION}_rhel9.tar.bz2 && \
    tar -xvjf agfhc-mi300_${AGFHC_VERSION}_rhel9.tar.bz2 && \
    rm -rf agfhc-mi300_${AGFHC_VERSION}_rhel9.tar.bz2 && \
    # Use AGFHC official installation script
    ./install && \
    # need to create this symbol link
    # otherwise amd-smi commands may complain cannot find libdrm_amdgpu and mess up the json output parsing
    ln /usr/lib64/libdrm_amdgpu.so.1 /usr/lib64/libdrm_amdgpu.so && \
    # clean up installer packages
    rm -rf *.tar.bz2 && \
    rm -rf *.rpm && \
    rm -rf rocm* && \
    rm -rf /var/cache/yum /var/cache/dnf && \
    dnf clean all

WORKDIR /

ADD amd-test-runner /amd-test-runner
ADD LICENSE /licenses/LICENSE
RUN chmod +x /amd-test-runner

# Set LD_LIBRARY_PATH for ROCm
ENV LD_LIBRARY_PATH=/opt/rocm/lib:$LD_LIBRARY_PATH

LABEL name="amd-device-test-runner" \ 
    maintainer="yan.sun3@amd.com,udaybhaskar.biluri@amd.com,shrey.ajmera@amd.com" \
    vendor="Advanced Micro Devices, Inc." \
    version="v1.4.1" \
    release="v1.4.1" \
    summary="AMD Device Test Runner performs troubleshooting and benchmarking tests on AMD GPUs across Kubernetes clusters." \
    description="AMD Device Test Runner ensures that GPUs are functioning correctly and efficiently by running a series of diagnostic tests and performance benchmarks. It helps identify issues, optimize GPU performance, and validate the readiness of GPU resources by running Rocm Validation Suite (RVS) and AMD GPU Field Health Check (AGFHC) tests."

ENTRYPOINT ["/amd-test-runner"]
