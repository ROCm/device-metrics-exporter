diff --git a/sw/nic/gpuagent/api/gpu.cc b/sw/nic/gpuagent/api/gpu.cc
index b76da8ec6ea..b605c6462f5 100644
--- a/sw/nic/gpuagent/api/gpu.cc
+++ b/sw/nic/gpuagent/api/gpu.cc
@@ -144,8 +144,28 @@ gpu_entry::update_handler(api_params_base *api_params) {
     if (unlikely(ret != SDK_RET_OK)) {
         return ret;
     }
-    // update the stashed spec if the gpu update goes through
-    memcpy(spec, &spec_, sizeof(aga_gpu_spec_t));
+    // spec fields are read once at create; write back what this set changed
+    if (upd_mask & AGA_GPU_UPD_ADMIN_STATE) {
+        spec_.admin_state = spec->admin_state;
+    }
+    if (upd_mask & AGA_GPU_UPD_OVERDRIVE_LEVEL) {
+        spec_.overdrive_level = spec->overdrive_level;
+    }
+    if (upd_mask & AGA_GPU_UPD_POWER_CAP) {
+        spec_.num_gpu_power_cap = spec->num_gpu_power_cap;
+        memcpy(spec_.gpu_power_cap, spec->gpu_power_cap,
+               sizeof(aga_gpu_power_cap_t) * spec->num_gpu_power_cap);
+    }
+    if (upd_mask & AGA_GPU_UPD_PERF_LEVEL) {
+        spec_.perf_level = spec->perf_level;
+    }
+    if (upd_mask & AGA_GPU_UPD_CLOCK_FREQ_RANGE) {
+        memcpy(spec_.clock_freq, spec->clock_freq,
+               sizeof(aga_gpu_clock_freq_range_t) * AGA_GPU_CLOCK_TYPE_MAX);
+    }
+    if (upd_mask & AGA_GPU_UPD_FAN_SPEED) {
+        spec_.fan_speed = spec->fan_speed;
+    }
     return ret;
 }
 
