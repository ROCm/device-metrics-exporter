DOCKER_REGISTRY ?= registry.test.pensando.io:5000
INSECURE_REGISTRY = $(DOCKER_REGISTRY)
DOCKER_BUILDER_TAG = v1.12
BUILD_BASE_IMAGE = $(DOCKER_REGISTRY)/ubuntu:22.04
RHEL_BASE_MIN_IMAGE = $(DOCKER_REGISTRY)/ubi9/ubi-minimal:9.8
TESTRUNNER_RHEL_BASE_IMAGE = $(DOCKER_REGISTRY)/ubi9/ubi:9.8
EXPORTER_SRIOV_BASE_IMAGE = $(DOCKER_REGISTRY)/ubi9/ubi-minimal:9.8
AZURE_BASE_IMAGE = $(DOCKER_REGISTRY)/azurelinux/coreos:3.0
AMDSMI_BASE_IMAGE = $(DOCKER_REGISTRY)/ubi9/ubi:9.4
AMDSMI_BASE_UBUNTU22 = $(BUILD_BASE_IMAGE)
AMDSMI_BASE_UBUNTU24 = $(DOCKER_REGISTRY)/ubuntu:24.04
AMDSMI_BASE_AZURE = $(AZURE_BASE_IMAGE)
GPUAGENT_BASE_IMAGE = $(BUILD_BASE_IMAGE)
ROCPROFILER_BASE_UBUNTU22 = $(DOCKER_REGISTRY)/ubuntu:22.04

# base image for the gpuagent builder container; full ubi9 (has dnf/yum) and
# glibc matched to the ubi9 exporter runtime so gpuagent links against the same libc
GPUAGENT_BUILDER_BASE_IMAGE = $(DOCKER_REGISTRY)/ubi9/ubi:9.8

GPUAGENT_BUILDER_IMAGE = $(DOCKER_REGISTRY)/gpuagent-builder:v2

# ROCm nightly tarball URL (used by docker-cicd and docker-test-runner-cicd
# targets). ROCM_VERSION must match the version string in the tarball so it extracts to
# /opt/rocm-${ROCM_VERSION}/ and LD_LIBRARY_PATH includes rocm_sysdeps/lib correctly.
# ROCm 7.14.0 RC2 (tarball last-modified 2026-07-08).
ROCM_VERSION ?= 7.14.0rc2
ROCM_TARBALL_URL ?= https://rocm.prereleases.amd.com/tarball-multi-arch/therock-dist-linux-multiarch-7.14.0rc2.tar.gz
RVS_TARBALL_URL ?= https://repo.amd.com/rocm/rvs/tarball/amdrocm7-rvs-1.4.24-454-Linux.tar.gz

# 0 = use the pre-staged amdsmi (26.5.0) + rocm_sysdeps libs from assets/ (default).
# 1 = re-extract amdsmi.h + libamd_smi.so + sysdeps from the therock tarball at build time.
AMDSMI_FROM_TARBALL ?= 0
